# ============================================================================
# SBPR.Trailborne — per-developer build configuration  (EXAMPLE / TEMPLATE)
# ----------------------------------------------------------------------------
# Copy this file to `.env` at the repo root and edit the paths to match YOUR
# machine, then build:
#
#     cp .env.example .env      # (PowerShell:  Copy-Item .env.example .env)
#     # ...edit .env...
#     dotnet build src/SBPR.Trailborne/SBPR.Trailborne.csproj -c Release
#
# `.env` is gitignored and MUST NOT be committed. These paths point at game
# binaries / BepInEx assemblies that are copyrighted and machine-specific.
#
# You do NOT need to set every variable. The build resolves each of the two
# required directories (Valheim Managed, BepInEx core) using the first option
# that is present, in this order:
#
#   Valheim:  VALHEIM_MANAGED  ->  VALHEIM_INSTALL (probed for the Managed dir)
#   BepInEx:  BEPINEX_CORE     ->  BEPINEX_PATH    (probed for the core dir)
#
# The helper scripts populate this for you:
#   scripts/setup.sh   /  scripts/setup.ps1      # locate Valheim + verify tools
#   scripts/fetch-sdk.sh / scripts/fetch-sdk.ps1 # obtain BepInEx core locally
# ============================================================================

# --- Valheim managed assemblies ---------------------------------------------
# REQUIRED (either VALHEIM_MANAGED or VALHEIM_INSTALL).
#
# VALHEIM_MANAGED: full path to the folder that contains assembly_valheim.dll,
# UnityEngine*.dll, etc. For the dedicated server this is
#   <install>/valheim_server_Data/Managed
# for the client it is
#   <install>/valheim_Data/Managed
#
# Linux dedicated-server example:
#VALHEIM_MANAGED=/home/you/valheim/server/valheim_server_Data/Managed
# Windows (Steam client) example:
#VALHEIM_MANAGED=C:\Program Files (x86)\Steam\steamapps\common\Valheim\valheim_Data\Managed
# macOS (Steam client) example:
#VALHEIM_MANAGED=/Users/you/Library/Application Support/Steam/steamapps/common/Valheim/valheim.app/Contents/Resources/Data/Managed

# VALHEIM_INSTALL (alternative): the game install ROOT. The build will probe
# for valheim_server_Data/Managed then valheim_Data/Managed underneath it.
#VALHEIM_INSTALL=/home/you/valheim/server

# --- BepInEx (HarmonyX) core assemblies -------------------------------------
# REQUIRED (either BEPINEX_CORE or BEPINEX_PATH).
#
# BEPINEX_CORE: full path to the BepInEx "core" folder that contains
# BepInEx.dll and 0Harmony.dll. After running scripts/fetch-sdk.sh this lives
# under the gitignored .sdk/ directory, e.g.:
#BEPINEX_CORE=/abs/path/to/repo/.sdk/BepInExPack_Valheim/BepInEx/core
#
# BEPINEX_PATH (alternative): the BepInEx ROOT (the folder that contains the
# `core` subfolder). The build will derive <BEPINEX_PATH>/core automatically.
#BEPINEX_PATH=/abs/path/to/repo/.sdk/BepInExPack_Valheim/BepInEx
