# Build artifacts
bin/
obj/
build/
*.dll
*.pdb
*.user
*.suo
*.zip

# Exception: bundled third-party mods we ship in the modpack ARE committed.
# Their DLLs are redistributable artifacts (known version, pinned, license-carried),
# not build output — so they must escape the blanket *.dll ignore above.
!assets/bundled-mods/**/*.dll

# Unity sidecar (not committed)
unity-project/Library/
unity-project/Temp/
unity-project/Obj/
unity-project/Build/
unity-project/Builds/
unity-project/Logs/
unity-project/UserSettings/
unity-project/MemoryCaptures/

# OS / editors
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# Decomp / reverse-engineering artifacts — NEVER COMMIT
# (these contain IronGate code; clean-room doctrine forbids inclusion)
**/decomp/
**/disasm/
**/*.decompiled.cs
**/subsystems/*.cs
**/types.tsv

# Local notes
.scratch/
SCRATCH.md

# Per-developer build config (machine-specific paths) — NEVER COMMIT
.env

# Fetched build SDK (BepInEx pack / managed reference assemblies) — NEVER COMMIT
# Obtained locally via scripts/fetch-sdk.sh; contains third-party/redistributable
# binaries that do not belong in source control.
.sdk/

# C# build artifacts
src/**/bin/
src/**/obj/

# Transient PR handoff artifacts (format-patch dumps, bundles, full-diffs)
.pr-c-handoff/
/dist/
/.ci/
